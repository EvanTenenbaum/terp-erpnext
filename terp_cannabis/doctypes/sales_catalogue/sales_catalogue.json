{
 "name": "Sales Catalogue",
 "doctype": "DocType",
 "module": "Terp Cannabis",
 "engine": "InnoDB",
 "editable_grid": 1,
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "catalogue_name",
   "label": "Catalogue Name",
   "fieldtype": "Data",
   "reqd": 1
  },
  {
   "fieldname": "customer",
   "label": "Customer",
   "fieldtype": "Link",
   "options": "Customer"
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "Draft\nPublished\nArchived",
   "default": "Draft"
  },
  {
   "fieldname": "share_token",
   "label": "Share Token",
   "fieldtype": "Data",
   "read_only": 1
  },
  {
   "fieldname": "token_expires_at",
   "label": "Token Expires At",
