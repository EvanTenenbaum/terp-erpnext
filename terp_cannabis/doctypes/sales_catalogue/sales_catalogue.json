  },
  {
   "fieldname": "created_by",
   "label": "Created By",
   "fieldtype": "Link",
   "options": "User"
  },
  {
   "fieldname": "notes",
   "label": "Notes",
   "fieldtype": "Small Text"
  },
  {
   "fieldname": "items",
   "label": "Items",
   "fieldtype": "Table",
