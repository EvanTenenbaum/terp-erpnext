{
 "name": "Live Shopping Session",
 "doctype": "DocType",
 "module": "Terp Cannabis",
 "engine": "InnoDB",
 "editable_grid": 1,
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "session_title",
   "label": "Session Title",
   "fieldtype": "Data",
   "reqd": 1
  },
  {
   "fieldname": "host",
   "label": "Host",
   "fieldtype": "Link",
   "options": "User",
   "reqd": 1
  },
  {
   "fieldname": "customer",
   "label": "Customer",
   "fieldtype": "Link",
   "options": "Customer"
  },
  {
   "fieldname": "room_code",
   "label": "Room Code",
   "fieldtype": "Data",
   "read_only": 1
  },
  {
   "fieldname": "status",
   "label": "Status",
   "fieldtype": "Select",
   "options": "Scheduled\nActive\nPaused\nEnded",
   "default": "Scheduled"
  },
  {
   "fieldname": "start_time",
   "label": "Start Time",
   "fieldtype": "Datetime"
  },
  {
   "fieldname": "end_time",
   "label": "End Time",
   "fieldtype": "Datetime"
  },
  {
   "fieldname": "items",
   "label": "Items",
   "fieldtype": "Table",
   "options": "Live Shopping Item"
  },
  {
   "fieldname": "converted_order",
   "label": "Converted Order",
   "fieldtype": "Link",
   "options": "Sales Order"
  }
 ],
 "autoname": "naming_series:LS-.YYYY.-.",
 "is_submittable": 0,
 "permissions": [
  {
   "role": "TERP Owner",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1
  },
  {
   "role": "TERP Accounts Manager",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "TERP Sales Rep",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "TERP Inventory Manager",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "TERP Fulfillment",
   "read": 1
  },
  {
   "role": "TERP Auditor",
   "read": 1
  }
 ]
}