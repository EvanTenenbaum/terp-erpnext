  },
  {
   "role": "TERP Accounts Manager",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "TERP Sales Rep",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "TERP Inventory Manager",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "TERP Fulfillment",
   "read": 1
  },
  {
   "role": "TERP Auditor",
   "read": 1
  }
 ]
}